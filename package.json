{
  "version": "0.1.0",
  "description": "service-template",
  "type": "module",
  "devDependencies": {
    "@devup-ui/bun-plugin": "^1.0",
    "@types/bun": "^1.3",
    "bun-test-env-dom": "^1.0",
    "eslint": "^9.39",
    "eslint-plugin-devup": "^2.0.17",
    "husky": "^9.1",
    "oxlint": "1.56"
  },
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "build": "bun run -F ./apps/front build",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "bun test",
